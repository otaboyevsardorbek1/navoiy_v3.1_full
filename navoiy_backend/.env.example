APP_NAME=Navoiy Asarlari API
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/navoiy_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/navoiy_db

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Content
CONTENT_DIR=content
SYNC_BUNDLE_VERSION=1
